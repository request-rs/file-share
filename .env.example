# 下载链接签名密钥（请修改为随机字符串）
APP_SECRET=your-random-secret-key-change-me

# 访问密码
ACCESS_PASSWORD=your_password_here

# 数据库连接字符串
DATABASE_URL=file:/data/file-share/db/database.sqlite

# 文件上传保存目录
UPLOAD_DIR=/data/file-share/uploads

# 临时分片目录
UPLOAD_TMP_DIR=/data/file-share/uploads/tmp

# 单文件最大上传大小 (MB)
MAX_UPLOAD_SIZE_MB=1024

# 前端最大上传大小 (MB)，需与后端一致
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=1024

# 分片大小 (MB)
UPLOAD_CHUNK_SIZE_MB=20

# 分片并发数
UPLOAD_CHUNK_CONCURRENCY=3

# 是否启用 Nginx X-Accel-Redirect 下载（生产环境建议 true）
USE_X_ACCEL_REDIRECT=false

# X-Accel-Redirect 内部路径前缀
X_ACCEL_REDIRECT_PATH=/protected-downloads/

# 应用名称
NEXT_PUBLIC_APP_NAME=文件分享中心
