# 下载链接签名密钥（请修改为随机字符串，服务器与本地必须一致）
APP_SECRET=your-random-secret-key-change-me

# 访问密码
ACCESS_PASSWORD=your_password_here

# 数据库连接字符串
# SQLite: file:/data/file-share/db/database.sqlite
# PostgreSQL: postgresql://user:password@localhost:5432/fileshare
DATABASE_URL=file:/data/file-share/db/database.sqlite

# 文件上传保存目录
UPLOAD_DIR=/data/file-share/uploads

# 单文件最大上传大小 (MB)
MAX_UPLOAD_SIZE_MB=500

# 前端最大上传大小 (MB)，需与后端一致
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=500

# 应用名称
NEXT_PUBLIC_APP_NAME=文件分享中心
